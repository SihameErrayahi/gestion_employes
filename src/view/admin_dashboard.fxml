<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.AdminDashboardController"
      style="-fx-background-color: #F1F5F9;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="🛡️ Dashboard Administrateur" styleClass="label-title"/>
    <Label text="Vue d'ensemble du système" styleClass="label-subtitle"/>

    <!-- Cartes statistiques -->
    <HBox spacing="20">
        <VBox styleClass="card">
            <Label text="🏢 Total Employés"/>
            <Label fx:id="totalEmployesLabel" text="—" styleClass="card-number"/>
            <Label text="dans l'entreprise" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
        </VBox>
        <VBox styleClass="card">
            <Label text="🧑‍💼 Comptes RH actifs"/>
            <Label fx:id="totalRHLabel" text="—" styleClass="card-number"/>
            <Label text="utilisateurs RH" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
        </VBox>
        <VBox styleClass="card">
            <Label text="🌴 Congés enregistrés"/>
            <Label fx:id="totalCongesLabel" text="—" styleClass="card-number"/>
            <Label text="demandes totales" style="-fx-text-fill: #F59E0B; -fx-font-size: 12px;"/>
        </VBox>
        <VBox styleClass="card">
            <Label text="💰 Masse salariale"/>
            <Label fx:id="masseSalarialeLabel" text="—" styleClass="card-number"/>
            <Label text="DH (salaires nets)" style="-fx-text-fill: #10B981; -fx-font-size: 12px;"/>
        </VBox>
    </HBox>

    <!-- Accès rapide avec boutons fonctionnels -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
        <Label text="⚡ Accès rapide"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
        <HBox spacing="15">
            <Button text="👥 Gérer les comptes RH"
                    onAction="#allerGestionRH"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13px;"/>
            <Button text="🏢 Voir tous les employés"
                    onAction="#allerEmployes"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13px;"/>
            <Button text="⚙️ Paramètres"
                    onAction="#allerParametres"
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13px;"/>
        </HBox>
    </VBox>

    <!-- Rappel droits admin -->
    <VBox spacing="8" style="-fx-background-color: #fff3cd; -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: #ffc107; -fx-border-radius: 12; -fx-border-width: 1;">
        <Label text="ℹ️ Droits Administrateur"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #856404;"/>
        <Label text="• Compte unique et non modifiable par les RH."
               style="-fx-text-fill: #664d03; -fx-font-size: 12px;"/>
        <Label text="• Créer, modifier et supprimer des comptes RH (max 2)."
               style="-fx-text-fill: #664d03; -fx-font-size: 12px;"/>
        <Label text="• Consulter la liste complète des employés en lecture seule."
               style="-fx-text-fill: #664d03; -fx-font-size: 12px;"/>
        <Label text="• Modifier votre propre mot de passe dans Paramètres."
               style="-fx-text-fill: #664d03; -fx-font-size: 12px;"/>
    </VBox>

</VBox>
