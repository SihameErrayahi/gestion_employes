<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.AdminDashboardController"
      style="-fx-background-color: #F1F5F9;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="🛡️ Dashboard Administrateur" styleClass="label-title"/>
    <Label text="Vue d'ensemble du système de gestion" styleClass="label-subtitle"/>

    <!-- Cartes statistiques -->
    <HBox spacing="20">

        <VBox styleClass="card">
            <Label text="👥 Total Employés"/>
            <Label fx:id="totalEmployesLabel" text="—" styleClass="card-number"/>
            <Label text="dans l'entreprise" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
        </VBox>

        <VBox styleClass="card">
            <Label text="🧑‍💼 Comptes RH actifs"/>
            <Label fx:id="totalRHLabel" text="—" styleClass="card-number"/>
            <Label text="utilisateurs RH" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
        </VBox>

        <VBox styleClass="card">
            <Label text="🌴 Congés en cours"/>
            <Label fx:id="totalCongesLabel" text="—" styleClass="card-number"/>
            <Label text="demandes actives" style="-fx-text-fill: #F59E0B; -fx-font-size: 12px;"/>
        </VBox>

        <VBox styleClass="card">
            <Label text="💰 Masse salariale"/>
            <Label fx:id="masseSalarialeLabel" text="—" styleClass="card-number"/>
            <Label text="DH ce mois" style="-fx-text-fill: #10B981; -fx-font-size: 12px;"/>
        </VBox>

    </HBox>

    <!-- Section accès rapide -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
        <Label text="⚡ Accès rapide Admin"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
        <HBox spacing="15">
            <Button text="➕ Créer compte RH"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand;"
                    onAction="#allerGestionRH"/>
            <Button text="🔑 Changer mot de passe"
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10 20; -fx-cursor: hand;"
                    onAction="#allerParametres"/>
        </HBox>
    </VBox>

    <!-- Section information admin -->
    <VBox spacing="10" style="-fx-background-color: #fff3cd; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #ffc107; -fx-border-radius: 12; -fx-border-width: 1;">
        <Label text="ℹ️ Rappel — Droits Administrateur"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #856404;"/>
        <Label text="• Vous êtes le seul administrateur du système (compte unique et fixe)."
               style="-fx-text-fill: #664d03; -fx-font-size: 13px;"/>
        <Label text="• Vous pouvez créer et supprimer des comptes RH."
               style="-fx-text-fill: #664d03; -fx-font-size: 13px;"/>
        <Label text="• Vous pouvez modifier votre propre mot de passe dans Paramètres."
               style="-fx-text-fill: #664d03; -fx-font-size: 13px;"/>
        <Label text="• Vous ne pouvez pas modifier les données employés (réservé aux RH)."
               style="-fx-text-fill: #664d03; -fx-font-size: 13px;"/>
    </VBox>

</VBox>
