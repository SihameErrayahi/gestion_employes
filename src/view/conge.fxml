<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.CongeController"
      style="-fx-background-color: #F1F5F9;">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="🌴 Gestion des Congés" styleClass="label-title"/>
        <Label fx:id="labelStats" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
    </HBox>

    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0, 0, 2);">

        <Label text="📋 Nouvelle demande de congé"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

        <HBox spacing="10">
            <ComboBox fx:id="comboEmploye"  promptText="Sélectionner un employé *" prefWidth="260"/>
            <ComboBox fx:id="comboType"     promptText="Type de congé *"            prefWidth="180"/>
        </HBox>

        <HBox spacing="10">
            <DatePicker fx:id="fieldDateDebut" promptText="Date début *"  prefWidth="190"/>
            <DatePicker fx:id="fieldDateFin"   promptText="Date fin *"    prefWidth="190"/>
            <Label fx:id="labelNbJours"
                   text="— jours"
                   style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#3B82F6; -fx-padding: 0 0 0 10;"/>
        </HBox>

        <HBox spacing="10">
            <TextField fx:id="fieldMotif" promptText="Motif (optionnel)" prefWidth="500"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="📋 Soumettre"   onAction="#demanderConge"  styleClass="button-primary"/>
            <Button text="✅ Approuver"   onAction="#approuverConge" styleClass="button-success"/>
            <Button text="❌ Refuser"     onAction="#refuserConge"   styleClass="button-danger"/>
            <Button text="🗑 Supprimer"   onAction="#supprimerConge" styleClass="button-secondary"/>
            <Button text="🔄 Vider"       onAction="#viderChamps"    styleClass="button-secondary"/>
        </HBox>

        <Label fx:id="labelMessage" wrapText="true"/>
    </VBox>

    <!-- FILTRE STATUT -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Filtrer par statut :" style="-fx-font-size: 13px;"/>
        <ComboBox fx:id="comboFiltreStatut" promptText="Tous" prefWidth="160"/>
    </HBox>

    <TableView fx:id="tableConges" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        text="ID"        prefWidth="45"/>
            <TableColumn fx:id="colEmployeNom" text="Employé"  prefWidth="160"/>
            <TableColumn fx:id="colDateDebut" text="Début"     prefWidth="100"/>
            <TableColumn fx:id="colDateFin"   text="Fin"       prefWidth="100"/>
            <TableColumn fx:id="colJours"     text="Jours"     prefWidth="60"/>
            <TableColumn fx:id="colType"      text="Type"      prefWidth="110"/>
            <TableColumn fx:id="colStatut"    text="Statut"    prefWidth="110"/>
            <TableColumn fx:id="colMotif"     text="Motif"     prefWidth="200"/>
        </columns>
        <placeholder><Label text="Aucune demande de congé"/></placeholder>
    </TableView>

</VBox>
