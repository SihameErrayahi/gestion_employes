<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.EmployeController"
      style="-fx-background-color: #F1F5F9;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="👥 Gestion des Employés" styleClass="label-title"/>
    <Label text="Ajouter, modifier et gérer les employés" styleClass="label-subtitle"/>

    <!-- Formulaire -->
    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
        <Label text="➕ Informations Employé"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Nom" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="nomField" promptText="Nom de famille" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Prénom" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="prenomField" promptText="Prénom" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Email" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField" promptText="email@exemple.com" styleClass="text-field"/>
            </VBox>
        </HBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Téléphone" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="telephoneField" promptText="06XXXXXXXX" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Poste" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="posteField" promptText="ex: Développeur" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Département" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="departementField" promptText="ex: Informatique" styleClass="text-field"/>
            </VBox>
        </HBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Date d'embauche (yyyy-MM-dd)" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="dateEmbaucheField" promptText="ex: 2024-01-15" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Salaire de base (DH)" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="salaireBaseField" promptText="ex: 8000.00" styleClass="text-field"/>
            </VBox>
        </HBox>

        <HBox spacing="10">
            <Button text="💾 Ajouter" onAction="#ajouterEmploye" styleClass="button-primary"/>
            <Button text="✏️ Modifier" onAction="#modifierEmploye"
                    style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-padding: 8 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="🗑 Annuler" onAction="#annuler" styleClass="button-secondary"/>
            <Label fx:id="messageLabel" text=""
                   style="-fx-text-fill: #10B981; -fx-font-size: 12px; -fx-padding: 0 0 0 10;"/>
        </HBox>
    </VBox>

    <!-- Tableau -->
    <VBox spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="📋 Liste des Employés"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
            <TextField fx:id="rechercheField" promptText="🔍 Rechercher..."
                       prefWidth="200" styleClass="text-field"
                       onKeyReleased="#rechercherEmploye"/>
        </HBox>

        <TableView fx:id="employeTable" VBox.vgrow="ALWAYS" prefHeight="280">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="110"/>
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="110"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="110"/>
                <TableColumn fx:id="colPoste" text="Poste" prefWidth="130"/>
                <TableColumn fx:id="colDepartement" text="Département" prefWidth="130"/>
                <TableColumn fx:id="colSalaire" text="Salaire Base" prefWidth="110"/>
            </columns>
        </TableView>

        <HBox spacing="10">
            <Button text="🗑 Supprimer" onAction="#supprimerEmploye" styleClass="button-danger"/>
            <Button text="🔄 Actualiser" onAction="#chargerDonnees" styleClass="button-secondary"/>
        </HBox>
    </VBox>

</VBox>