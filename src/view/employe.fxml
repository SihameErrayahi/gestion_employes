<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.EmployeController"
      style="-fx-background-color: #F1F5F9;">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- TITRE + COMPTEUR -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="👥 Gestion des Employés" styleClass="label-title"/>
        <Label fx:id="labelNbEmployes" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
    </HBox>

    <!-- FORMULAIRE -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0, 0, 2);">

        <Label text="📋 Informations de l'employé"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

        <!-- Ligne 1 : Nom + Prénom + Email + Téléphone -->
        <HBox spacing="10" alignment="TOP_LEFT">

            <!-- NOM -->
            <VBox spacing="2">
                <TextField fx:id="fieldNom" promptText="Nom *" prefWidth="160"/>
                <Label fx:id="errNom" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;" wrapText="true" prefWidth="160"/>
            </VBox>

            <!-- PRÉNOM -->
            <VBox spacing="2">
                <TextField fx:id="fieldPrenom" promptText="Prénom *" prefWidth="160" disable="true"/>
                <Label fx:id="errPrenom" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;" wrapText="true" prefWidth="160"/>
            </VBox>

            <!-- EMAIL -->
            <VBox spacing="2">
                <TextField fx:id="fieldEmail" promptText="Email *" prefWidth="200" disable="true"/>
                <Label fx:id="errEmail" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;" wrapText="true" prefWidth="200"/>
            </VBox>

            <!-- TÉLÉPHONE -->
            <VBox spacing="2">
                <TextField fx:id="fieldTelephone" promptText="Téléphone * (06XXXXXXXX)" prefWidth="160" disable="true"/>
                <Label fx:id="errTelephone" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;" wrapText="true" prefWidth="160"/>
            </VBox>

        </HBox>

        <!-- Ligne 2 : Poste + Département + Date embauche + Salaire -->
        <HBox spacing="10">
            <TextField fx:id="fieldPoste"         promptText="Poste *"          prefWidth="160" disable="true"/>
            <ComboBox fx:id="comboDepartement"    promptText="Département *"    prefWidth="160" disable="true"/>
            <DatePicker fx:id="fieldDateEmbauche" promptText="Date embauche *"  prefWidth="175" disable="true"/>
            <TextField fx:id="fieldSalaireBase"   promptText="Salaire base *"   prefWidth="135" disable="true"/>
        </HBox>

        <!-- Ligne 3 : CIN + Adresse + Statut -->
        <HBox spacing="10" alignment="TOP_LEFT">
            <TextField fx:id="fieldCin" promptText="CIN" prefWidth="140" disable="true"/>

            <!-- ADRESSE -->
            <VBox spacing="2">
                <TextField fx:id="fieldAdresse" promptText="Adresse (ex: 12 Rue Hassan)" prefWidth="300" disable="true"/>
                <Label fx:id="errAdresse" style="-fx-text-fill: #EF4444; -fx-font-size: 11px;" wrapText="true" prefWidth="300"/>
            </VBox>

            <ComboBox fx:id="comboStatut" promptText="Statut" prefWidth="140" disable="true"/>
        </HBox>

        <!-- Boutons -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="➕ Ajouter"   onAction="#ajouterEmploye"   styleClass="button-success"/>
            <Button text="✏️ Modifier"  onAction="#modifierEmploye"  styleClass="button-primary"/>
            <Button text="🗑 Supprimer" onAction="#supprimerEmploye" styleClass="button-danger"/>
            <Button text="🔄 Vider"     onAction="#viderChamps"      styleClass="button-secondary"/>
        </HBox>

        <TextArea fx:id="labelMessage"
                  editable="false"
                  wrapText="true"
                  prefHeight="60"
                  maxHeight="100"
                  style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-padding: 4 0 0 0;"/>
    </VBox>

    <!-- BARRE DE RECHERCHE -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="🔍" style="-fx-font-size: 16px;"/>
        <TextField fx:id="fieldRecherche" promptText="Rechercher par nom, prénom, poste, département, email..."
                   prefWidth="420"/>
    </HBox>

    <!-- TABLE -->
    <TableView fx:id="tableEmployes" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"           text="ID"           prefWidth="45"/>
            <TableColumn fx:id="colNom"          text="Nom"          prefWidth="110"/>
            <TableColumn fx:id="colPrenom"       text="Prénom"       prefWidth="110"/>
            <TableColumn fx:id="colPoste"        text="Poste"        prefWidth="120"/>
            <TableColumn fx:id="colDepartement"  text="Département"  prefWidth="120"/>
            <TableColumn fx:id="colEmail"        text="Email"        prefWidth="170"/>
            <TableColumn fx:id="colTelephone"    text="Téléphone"    prefWidth="105"/>
            <TableColumn fx:id="colDateEmbauche" text="Embauche"     prefWidth="95"/>
            <TableColumn fx:id="colSalaireBase"  text="Salaire base" prefWidth="100"/>
            <TableColumn fx:id="colAnciennete"   text="Ancienneté"   prefWidth="85"/>
            <TableColumn fx:id="colStatut"       text="Statut"       prefWidth="90"/>
        </columns>
        <placeholder><Label text="Aucun employé trouvé"/></placeholder>
    </TableView>

</VBox>