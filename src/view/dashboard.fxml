<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      style="-fx-background-color: #F1F5F9;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="📊 Dashboard RH" styleClass="label-title"/>
    <Label text="Bienvenue dans votre espace de gestion" styleClass="label-subtitle"/>

    <!-- Cartes statistiques -->
    <HBox spacing="20">
        <VBox styleClass="card">
            <Label text="👥 Total Employés"/>
            <Label fx:id="totalEmployes" styleClass="card-number"/>
            <Label text="+3 ce mois" style="-fx-text-fill: #10B981; -fx-font-size: 12px;"/>
        </VBox>

        <VBox styleClass="card">
            <Label text="🌴 Congés en cours"/>
            <Label text="5" styleClass="card-number"/>
            <Label text="2 en attente" style="-fx-text-fill: #F59E0B; -fx-font-size: 12px;"/>
        </VBox>

        <VBox styleClass="card">
            <Label text="💰 Masse salariale"/>
            <Label text="142.5K" styleClass="card-number"/>
            <Label text="DH ce mois" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
        </VBox>

        <VBox styleClass="card">
            <Label text="⭐ Taux présence"/>
            <Label text="94%" styleClass="card-number"/>
            <Label text="+2% vs mois dernier" style="-fx-text-fill: #10B981; -fx-font-size: 12px;"/>
        </VBox>
    </HBox>

    <!-- Section rapide -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
        <Label text="⚡ Actions rapides" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
        
        <HBox spacing="15">
            <Button text="➕ Nouvel employé" styleClass="button-primary"/>
            <Button text="📅 Nouveau congé" styleClass="button-secondary"/>
            <Button text="💰 Générer salaires" styleClass="button-success"/>
        </HBox>
    </VBox>

</VBox>