<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.SalaireController"
      style="-fx-background-color: #F1F5F9;">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="💰 Gestion des Salaires" styleClass="label-title"/>
        <Label fx:id="labelStats" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
    </HBox>

    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0, 0, 2);">

        <Label text="📋 Saisie de salaire"
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

        <HBox spacing="10">
            <ComboBox fx:id="comboEmploye" promptText="Sélectionner un employé *" prefWidth="280"/>
            <TextField fx:id="fieldMois" promptText="Mois * (yyyy-MM)" prefWidth="160"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="fieldBase"     promptText="Salaire base *" prefWidth="160"/>
            <TextField fx:id="fieldPrimes"   promptText="Primes"         prefWidth="160"/>
            <TextField fx:id="fieldRetenues" promptText="Retenues"       prefWidth="160"/>
            <VBox spacing="2" style="-fx-padding: 0 0 0 10;">
                <Label text="Salaire Net" style="-fx-font-size:12px; -fx-text-fill:#64748B;"/>
                <Label fx:id="labelNet" text="— DH"
                       style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#10B981;"/>
            </VBox>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="➕ Ajouter"   onAction="#ajouterSalaire"   styleClass="button-success"/>
            <Button text="🗑 Supprimer" onAction="#supprimerSalaire" styleClass="button-danger"/>
            <Button text="🔄 Vider"     onAction="#viderChamps"      styleClass="button-secondary"/>
        </HBox>

        <Label fx:id="labelMessage" wrapText="true"/>
    </VBox>

    <!-- FILTRE PAR EMPLOYE -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Filtrer par employé :" style="-fx-font-size: 13px;"/>
        <ComboBox fx:id="comboFiltreEmploye" promptText="Tous les employés" prefWidth="240"/>
    </HBox>

    <TableView fx:id="tableSalaires" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"          text="ID"           prefWidth="45"/>
            <TableColumn fx:id="colEmployeNom"  text="Employé"      prefWidth="160"/>
            <TableColumn fx:id="colMois"        text="Mois"         prefWidth="90"/>
            <TableColumn fx:id="colBase"        text="Base (DH)"    prefWidth="110"/>
            <TableColumn fx:id="colPrimes"      text="Primes (DH)"  prefWidth="110"/>
            <TableColumn fx:id="colRetenues"    text="Retenues (DH)" prefWidth="115"/>
            <TableColumn fx:id="colNet"         text="Net (DH)"     prefWidth="120"/>
        </columns>
        <placeholder><Label text="Aucun salaire enregistré"/></placeholder>
    </TableView>

</VBox>
