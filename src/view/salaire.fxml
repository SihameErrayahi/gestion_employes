<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.SalaireController"
      style="-fx-background-color: #F1F5F9;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="💰 Gestion des Salaires" styleClass="label-title"/>
    <Label text="Suivi et gestion de la paie des employés" styleClass="label-subtitle"/>

    <!-- Formulaire -->
    <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
        <Label text="➕ Enregistrer un Salaire"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Employé" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <ComboBox fx:id="employeCombo" promptText="Sélectionner un employé"
                          maxWidth="Infinity" styleClass="combo-box"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Mois (yyyy-MM)" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="moisField" promptText="ex: 2025-04"
                           styleClass="text-field"/>
            </VBox>
        </HBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Salaire de base (DH)" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="salaireBaseField" promptText="0.00" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Primes (DH)" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="primesField" promptText="0.00" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Retenues (DH)" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="retenuesField" promptText="0.00" styleClass="text-field"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Salaire Net (DH)" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                <TextField fx:id="salaireNetField" promptText="Calculé auto" editable="false"
                           style="-fx-background-color: #F1F5F9; -fx-border-color: #E2E8F0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 8 12; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
            </VBox>
        </HBox>

        <HBox spacing="10">
            <Button text="💾 Enregistrer le salaire" onAction="#ajouterSalaire"
                    styleClass="button-primary"/>
            <Button text="🧮 Calculer le net" onAction="#calculerNet"
                    styleClass="button-secondary"/>
            <Button text="🗑 Annuler" onAction="#annuler"
                    styleClass="button-secondary"/>
            <Label fx:id="messageLabel" text=""
                   style="-fx-text-fill: #10B981; -fx-font-size: 12px; -fx-padding: 0 0 0 10;"/>
        </HBox>
    </VBox>

    <!-- Tableau -->
    <VBox spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20;">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="📋 Historique des Salaires"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
            <Label text="Filtrer par mois :" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
            <TextField fx:id="filtreField" promptText="yyyy-MM" prefWidth="110" styleClass="text-field"/>
            <Button text="🔍 Filtrer" onAction="#filtrerParMois" styleClass="button-secondary"/>
            <Button text="Tous" onAction="#chargerDonnees" styleClass="button-secondary"/>
        </HBox>

        <TableView fx:id="salaireTable" VBox.vgrow="ALWAYS" prefHeight="280">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colEmploye" text="Employé ID" prefWidth="100"/>
                <TableColumn fx:id="colMois" text="Mois" prefWidth="90"/>
                <TableColumn fx:id="colBase" text="Base (DH)" prefWidth="110"/>
                <TableColumn fx:id="colPrimes" text="Primes (DH)" prefWidth="110"/>
                <TableColumn fx:id="colRetenues" text="Retenues (DH)" prefWidth="120"/>
                <TableColumn fx:id="colNet" text="Net (DH)" prefWidth="110"/>
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="🗑 Supprimer" onAction="#supprimerSalaire" styleClass="button-danger"/>
            <Button text="🔄 Actualiser" onAction="#chargerDonnees" styleClass="button-secondary"/>
            <Label text="Total masse salariale : " style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
            <Label fx:id="totalLabel" text="0.00 DH"
                   style="-fx-font-weight: bold; -fx-text-fill: #10B981; -fx-font-size: 14px;"/>
        </HBox>
    </VBox>

</VBox>